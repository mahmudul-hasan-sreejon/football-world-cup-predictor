# Copy this file to `.env.local` and adjust as needed:
#   cp .env.example .env.local
#
# All values are optional. On Vercel the canonical URL is filled in
# automatically from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL, so you
# only need to set NEXT_PUBLIC_SITE_URL when serving from a custom domain
# (or another host). See lib/site.ts.

# Canonical site URL used for SEO metadata, robots.txt, and sitemap.xml.
# Include the trailing slash. Defaults to http://localhost:3000/ locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000/

# Tournament this predictor covers, stored with each newsletter sign-up.
# Defaults to "FIFA World Cup 2026" (see lib/site.ts).
NEXT_PUBLIC_TOURNAMENT=FIFA World Cup 2026

# Vercel Postgres connection string, used by the /api/subscribe route to store
# newsletter sign-ups (see lib/subscribers.ts). On Vercel this is injected
# automatically when you attach a Postgres store; set it locally to test.
POSTGRES_URL=postgres://user:password@host:5432/dbname

# Upstash Redis REST credentials, used to rate-limit /api/subscribe per IP
# (see lib/rate-limit.ts). On Vercel these are injected automatically when you
# attach an Upstash for Redis store — the Marketplace integration names them
# KV_REST_API_URL / KV_REST_API_TOKEN, and the code reads either naming. When
# both are unset the limiter is disabled and every request is allowed, so the
# app still runs locally without them.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
